# Ward Academy — environment variables (template; no real values here)
# Copy to .env.local and fill in. .env.local is gitignored.

# --- Supabase (EU / Frankfurt) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret — never exposed to the browser:
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (Session pooler URI) — used only by db:migrate /
# db:status scripts. Use an alphanumeric DB password (no special characters).
SUPABASE_DB_URL=

# --- Anthropic (Claude API) — server only ---
ANTHROPIC_API_KEY=
# Optional: override the generation model (default: claude-sonnet-4-6)
ANTHROPIC_GENERATION_MODEL=
